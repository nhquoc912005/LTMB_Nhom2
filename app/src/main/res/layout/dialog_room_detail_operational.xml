<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_calendar"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvRoomTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phòng 101"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/black" />

    <LinearLayout
        android:id="@+id/layoutInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvRoomTitle"
        android:layout_marginTop="20dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Trạng thái:"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edittext_border"
                android:backgroundTint="#FAD4D4"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Đang sử dụng"
                android:textColor="#E06666"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Dự kiến:"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvCheckIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edittext_border"
                android:drawableEnd="@android:drawable/ic_menu_today"
                android:drawablePadding="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="20 Th8 2025, 14:00" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="đến:"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvCheckOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edittext_border"
                android:drawableEnd="@android:drawable/ic_menu_today"
                android:drawablePadding="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="21 Th8 2025, 12:00" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiền phòng:"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvRoomFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="1,600,000"
                android:textSize="16sp"
                android:textColor="#888888"/>
        </RelativeLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddServiceToRoom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutInfo"
        android:layout_alignParentEnd="true"
        android:backgroundTint="@color/white"
        android:src="@android:drawable/ic_input_add"
        app:fabSize="mini"
        app:tint="@color/black" />
</RelativeLayout>