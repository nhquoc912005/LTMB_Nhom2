<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EFE9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="#D1C19F">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="30dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="29dp"
                android:layout_height="29dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="25dp"
                android:src="@drawable/ic_hamburger"
                app:tint="#404040"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </RelativeLayout>

        <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F3F0"
            android:padding="16dp">

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_toStartOf="@+id/btnSearch"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search_input"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:fontFamily="@font/livvic"
                android:hint="Tìm kiếm dịch vụ, bồi thường"
                android:padding="12dp"
                android:textSize="16sp"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="#D86030"
                android:fontFamily="@font/livvic"
                android:text="Tìm kiếm"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:elevation="0dp"
                android:stateListAnimator="@null" />

            <LinearLayout
                android:id="@+id/layoutTabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/edtSearch"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_tab_container"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTabService"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab_left_active"
                    android:gravity="center"
                    android:padding="10dp"
                    android:fontFamily="@font/livvic"
                    android:text="Dịch vụ"
                    android:textColor="#C58959"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvTabAsset"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:fontFamily="@font/livvic"
                    android:text="Bồi thường"
                    android:textColor="@color/black"
                    android:textSize="16sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcvServices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/layoutTabs"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingBottom="80dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="24dp"
                android:backgroundTint="@color/white"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/black"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp" />

        </RelativeLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>