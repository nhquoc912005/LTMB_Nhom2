<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.bottomnavigation.BottomNavigationView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_navigation"
    android:layout_width="match_parent"
    android:layout_height="@dimen/app_bottom_nav_height"
    android:background="@color/app_shell_beige"
    app:backgroundTint="@color/app_shell_beige"
    app:itemActiveIndicatorStyle="@style/AppBottomNavigationActiveIndicator"
    app:itemIconSize="24dp"
    app:itemIconTint="@color/nav_item_color_selector"
    app:itemRippleColor="@color/bottom_nav_ripple"
    app:itemTextAppearanceActive="@style/BottomNavLabelActive"
    app:itemTextAppearanceInactive="@style/BottomNavLabel"
    app:itemTextColor="@color/nav_item_color_selector"
    app:labelVisibilityMode="labeled"
    app:menu="@menu/bottom_nav_menu" />
