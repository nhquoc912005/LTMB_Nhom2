<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6EFE9"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/tabCheckIn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:fontFamily="@font/livvic"
            android:gravity="center"
            android:text="Nhận phòng"
            android:textColor="#888888" />
        <TextView
            android:id="@+id/tabCheckOut"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:fontFamily="@font/livvic"
            android:gravity="center"
            android:text="Trả phòng"
            android:textColor="#C68C53" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/stay_content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
