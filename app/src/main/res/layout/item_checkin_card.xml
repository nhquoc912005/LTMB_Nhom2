<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvGuestName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Văn A"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/livvic"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#EEEEEE" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Left Column -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true">

                <TextView
                    android:id="@+id/tvRoomNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phòng 101"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>

                <TextView
                    android:id="@+id/tvPhoneNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0901234567"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="nguyenvana@email.com"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>

                <TextView
                    android:id="@+id/tvStayPeriod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="14/02/2026 - 16/02/2026"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>
            </LinearLayout>

            <!-- Right Column -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentEnd="true"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvTotalGuests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng số người: 2"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>

                <TextView
                    android:id="@+id/tvAdults"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Người lớn: 2"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>

                <TextView
                    android:id="@+id/tvChildren"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Trẻ em: 0"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:fontFamily="@font/livvic"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChangeRoom"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_outline"
                android:drawableStart="@drawable/ic_sync"
                android:drawablePadding="8dp"
                android:paddingHorizontal="12dp"
                android:text="Đổi phòng"
                android:textAllCaps="false"
                android:textColor="#333333"
                android:textSize="14sp"
                android:fontFamily="@font/livvic"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCheckIn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_solid"
                android:text="Nhận phòng"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:fontFamily="@font/livvic"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
