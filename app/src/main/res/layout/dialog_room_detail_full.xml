<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="40dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/llMainContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
                        <TextView android:id="@+id/tvRoomTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phòng 101" android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />
                        <ImageButton android:id="@+id/btnClose" android:layout_width="30dp" android:layout_height="30dp" android:layout_alignParentEnd="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="@color/black" />
                    </RelativeLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:gravity="center_vertical">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Trạng thái:" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_edittext_border" android:backgroundTint="#FAD4D4" android:paddingHorizontal="16dp" android:paddingVertical="6dp" android:text="Đang sử dụng" android:textColor="#E06666" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Dự kiến:" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:id="@+id/tvCheckIn" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#F2F2F2" android:drawableEnd="@android:drawable/ic_menu_today" android:padding="12dp" android:text="20 Th8 2025,\n14:00" android:textColor="#555555" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:gravity="center_vertical">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="đến:" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:id="@+id/tvCheckOut" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#F2F2F2" android:drawableEnd="@android:drawable/ic_menu_today" android:padding="12dp" android:text="21 Th8 2025,\n12:00" android:textColor="#555555" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="20dp"/>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiền phòng:" android:textColor="@color/black" android:textSize="18sp"/>
                        <TextView android:id="@+id/tvRoomFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="1,600,000" android:textColor="#555555" android:textSize="18sp"/>
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvSectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp"
                        android:text="DỊCH VỤ"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutAddedItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/layoutActionButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btnCancelChanges"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/white"
                            android:text="Hủy"
                            android:textColor="#D86030" />

                        <Button
                            android:id="@+id/btnSaveChanges"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#D86030"
                            android:text="Lưu"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabAddServiceToRoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignBottom="@id/llMainContent"
                    android:layout_alignParentEnd="true"
                    android:layout_marginBottom="-16dp"
                    android:layout_marginEnd="-8dp"
                    android:backgroundTint="#D86030"
                    android:src="@android:drawable/ic_input_add"
                    app:fabSize="normal"
                    app:tint="@color/white" />

            </RelativeLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</RelativeLayout>